---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('devotion', ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="今日のみことば — GSFGrace"
  description="毎日の短い聖書の黙想。日本橋から届く言葉の糧。"
  lang="ja"
>
  <header class="page-header">
    <p class="page-tag">今日のみことば / 오늘의 묵상</p>
    <h1>みことばの黙想</h1>
    <p class="page-desc">日々の聖書箇所と短い黙想をお届けします。</p>
  </header>

  {posts.length === 0 ? (
    <div class="empty-state">
      <p>準備中です。まずは <a href="/story">はじめての方へ</a> をお読みください。</p>
    </div>
  ) : (
    <ul class="post-list" role="list">
      {posts.map((post) => (
        <li class="post-item">
          <a href={`/devotion/${post.slug}`} class="post-link" id={`devotion-${post.slug}`}>
            {post.data.passage && <span class="post-passage">{post.data.passage}</span>}
            <h2 class="post-title">{post.data.title}</h2>
            <time class="post-date" datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('ja-JP')}
            </time>
          </a>
        </li>
      ))}
    </ul>
  )}

  <div class="page-story-cta">
    <a href="/story" id="devotion-story-link">この記事を書いた人は？ →</a>
  </div>
</BaseLayout>

<style>
  .page-header {
    padding: 2rem 0;
    border-bottom: 1px solid var(--color-line);
    margin-bottom: 2rem;
  }
  .page-tag {
    font-size: 0.72rem;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    font-family: var(--font-sans);
  }
  .page-header h1 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-text);
    letter-spacing: -0.02em;
    font-family: var(--font-serif);
  }
  .page-desc {
    color: var(--color-muted);
    margin-top: 0.5rem;
    font-size: 0.9rem;
    font-family: var(--font-sans);
  }
  .empty-state {
    padding: 3rem 0;
    color: var(--color-muted);
    text-align: center;
    font-family: var(--font-sans);
  }
  .post-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .post-link {
    display: block;
    padding: 1.25rem;
    border: 1px solid var(--color-line);
    border-radius: 4px;
    text-decoration: none;
    transition: border-color 0.15s, box-shadow 0.15s;
    background: var(--color-surface);
  }
  .post-link:hover {
    border-color: var(--color-accent-soft);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
    text-decoration: none;
  }
  .post-passage {
    font-size: 0.75rem;
    color: var(--color-accent);
    font-weight: 600;
    letter-spacing: 0.05em;
    display: block;
    margin-bottom: 0.25rem;
    font-family: var(--font-sans);
  }
  .post-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: 0.25rem;
    font-family: var(--font-serif);
  }
  .post-date {
    font-size: 0.75rem;
    color: #a8a29e;
    font-family: var(--font-sans);
  }
  .page-story-cta {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-line);
    text-align: center;
    font-size: 0.9rem;
    font-family: var(--font-sans);
  }
</style>
