---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('arche', ({ data }) => !data.draft && data.lang === 'ja');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout
  title="ἀρχή — GSFGrace"
  description="神学、哲学、文化——信仰の知的深みへ。"
  lang="ja"
>
  <header class="page-header">
    <p class="page-tag">ἀρχή / 아르케</p>
    <h1 class="arche-title">ἀρχή</h1>
    <p class="page-desc">神学、哲学、文化——信仰の知的深みへ。</p>
  </header>

  {posts.length === 0 ? (
    <div class="empty-state">
      <p>準備中です。まずは <a href="/story">はじめての方へ</a> をお読みください。</p>
    </div>
  ) : (
    <ul class="post-list" role="list">
      {posts.map((post) => (
        <li>
          <a href={`/arche/${post.id.split('/').pop()}`} class="post-link" id={`arche-${post.id.split('/').pop()}`}>
            <h2 class="post-title">{post.data.title}</h2>
            {post.data.description && <p class="post-desc">{post.data.description}</p>}
            <div class="post-meta">
              <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                {post.data.pubDate.toLocaleDateString('ja-JP')}
              </time>
              {post.data.author !== '승주' && (
                <span class="post-byline">글 · {post.data.author}</span>
              )}
            </div>
          </a>
        </li>
      ))}
    </ul>
  )}

  <div class="page-story-cta">
    <a href="/story" id="arche-story-link">GSFGraceについて →</a>
  </div>
</BaseLayout>

<style>
  .page-header { padding: 2rem 0; border-bottom: 1px solid var(--color-line); margin-bottom: 2rem; }
  .page-tag { font-size: 0.72rem; letter-spacing: 0.15em; color: var(--color-accent); font-weight: 600; text-transform: uppercase; margin-bottom: 0.5rem; font-family: var(--font-sans); }
  .arche-title { font-size: 2rem; font-weight: 700; color: var(--color-text); letter-spacing: -0.02em; font-family: var(--font-serif); }
  .page-desc { color: var(--color-muted); margin-top: 0.5rem; font-size: 0.9rem; font-family: var(--font-sans); }
  .empty-state { padding: 3rem 0; color: var(--color-muted); text-align: center; font-family: var(--font-sans); }
  .post-list { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .post-link { display: block; padding: 1.25rem; border: 1px solid var(--color-line); border-radius: 4px; text-decoration: none; transition: border-color 0.15s, box-shadow 0.15s; background: var(--color-surface); }
  .post-link:hover { border-color: var(--color-accent-soft); box-shadow: 0 2px 8px rgba(0,0,0,0.05); text-decoration: none; }
  .post-title { font-size: 1rem; font-weight: 600; color: var(--color-text); margin-bottom: 0.25rem; font-family: var(--font-serif); }
  .post-desc { font-size: 0.85rem; color: var(--color-muted); margin-bottom: 0.25rem; line-height: 1.5; font-family: var(--font-sans); }
  .post-date { font-size: 0.75rem; color: #a8a29e; font-family: var(--font-sans); }
  .post-meta { display: flex; align-items: center; gap: 0.75rem; margin-top: 0.25rem; }
  .post-byline { font-size: 0.75rem; color: var(--color-accent); font-family: var(--font-sans); font-style: italic; }
  .page-story-cta { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--color-line); text-align: center; font-size: 0.9rem; font-family: var(--font-sans); }
</style>
