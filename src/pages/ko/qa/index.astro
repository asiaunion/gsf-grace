---
/**
 * /ko/qa/index.astro — 궁금한 질문 KO
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('qa', ({ data }) => !data.draft && data.lang === 'ko');
posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const tags = [
  { key: 'suffering', label: '고통', emoji: '💔' },
  { key: 'death',     label: '죽음', emoji: '🌿' },
  { key: 'science',   label: '과학', emoji: '🔬' },
  { key: 'bible',     label: '성경', emoji: '📖' },
  { key: 'jesus',     label: '예수님', emoji: '✝️' },
  { key: 'church',    label: '교회', emoji: '🏛️' },
  { key: 'prayer',    label: '기도', emoji: '🙏' },
  { key: 'salvation', label: '구원', emoji: '🕊️' },
  { key: 'relations', label: '인간관계', emoji: '🤝' },
  { key: 'money',     label: '돈', emoji: '💴' },
  { key: 'work',      label: '직장', emoji: '💼' },
] as const;

type TagKey = typeof tags[number]['key'];

const groupedByTag = tags.reduce((acc, { key }) => {
  acc[key] = posts.filter((p) => p.data.tag === key);
  return acc;
}, {} as Record<TagKey, typeof posts>);
---

<BaseLayout
  title="궁금한 질문 — GSFGrace"
  description="하나님이 고통을 허락하시는 이유? 기독교에 대한 솔직한 질문에 답합니다."
  lang="ko"
>
  <header class="page-header">
    <p class="page-tag">궁금한 질문 / 疑問に答える</p>
    <h1>솔직한 질문들</h1>
    <p class="page-desc">
      하나님이 고통을 허락하시는 이유?<br />
      과학과 신앙은 모순인가? — 함께 생각해 봅시다.
    </p>
  </header>

  <nav class="tag-nav" aria-label="질문 카테고리">
    {tags.map(({ key, label, emoji }) => (
      <a href={`/ko/qa/${key}`} class="tag-pill" id={`qa-tag-${key}`}>
        {emoji} {label}
        {groupedByTag[key].length > 0 && (
          <span class="tag-count">{groupedByTag[key].length}</span>
        )}
      </a>
    ))}
  </nav>

  {posts.length === 0 ? (
    <div class="empty-state">
      <p>준비 중입니다. 먼저 <a href="/ko/story">처음 오셨나요?</a>를 읽어 주세요.</p>
    </div>
  ) : (
    <div class="qa-list">
      {tags.map(({ key, label, emoji }) => groupedByTag[key].length > 0 && (
        <section class="qa-section" aria-labelledby={`section-${key}`}>
          <h2 id={`section-${key}`} class="section-heading">{emoji} {label}</h2>
          <ul role="list" class="post-list">
            {groupedByTag[key].map((post) => (
              <li>
                <a href={`/ko/qa/${post.data.tag}/${post.id.split('/').pop()}`} class="post-link" id={`qa-ko-${post.id.split('/').pop()}`}>
                  <p class="post-question">{post.data.question}</p>
                  <h3 class="post-title">{post.data.title}</h3>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  )}

  <div class="page-story-cta">
    <a href="/ko/story" id="qa-story-link">이 글을 쓴 사람은? →</a>
  </div>
</BaseLayout>

<style>
  .page-header { padding: 2rem 0; border-bottom: 1px solid var(--color-line); margin-bottom: 2rem; }
  .page-tag { font-size: 0.72rem; letter-spacing: 0.15em; color: var(--color-accent); font-weight: 600; text-transform: uppercase; margin-bottom: 0.5rem; font-family: var(--font-sans); }
  .page-header h1 { font-size: 2rem; font-weight: 700; color: var(--color-text); letter-spacing: -0.02em; font-family: var(--font-serif); }
  .page-desc { color: var(--color-muted); margin-top: 0.5rem; font-size: 0.9rem; line-height: 1.7; font-family: var(--font-sans); }
  .tag-nav { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 2.5rem; }
  .tag-pill { display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.35rem 0.75rem; border: 1px solid var(--color-line); border-radius: 999px; font-size: 0.8rem; color: var(--color-muted); text-decoration: none; transition: border-color 0.15s, background 0.15s; background: var(--color-surface); font-family: var(--font-sans); }
  .tag-pill:hover { border-color: var(--color-accent); color: var(--color-accent); text-decoration: none; background: var(--color-accent-soft); }
  .tag-count { background: var(--color-accent-soft); color: var(--color-accent); font-size: 0.7rem; padding: 0 0.3rem; border-radius: 999px; font-weight: 700; }
  .empty-state { padding: 3rem 0; color: var(--color-muted); text-align: center; font-family: var(--font-sans); }
  .qa-section { margin-bottom: 2.5rem; }
  .section-heading { font-size: 1rem; font-weight: 700; color: var(--color-text); margin-bottom: 0.75rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--color-line); font-family: var(--font-serif); }
  .post-list { list-style: none; display: flex; flex-direction: column; gap: 0.4rem; }
  .post-link { display: block; padding: 1rem 1.25rem; border: 1px solid var(--color-line); border-radius: 4px; text-decoration: none; transition: border-color 0.15s, box-shadow 0.15s; background: var(--color-surface); }
  .post-link:hover { border-color: var(--color-accent-soft); box-shadow: 0 2px 8px rgba(0,0,0,0.05); text-decoration: none; }
  .post-question { font-size: 0.78rem; color: var(--color-muted); font-style: italic; margin-bottom: 0.2rem; font-family: var(--font-sans); }
  .post-title { font-size: 0.95rem; font-weight: 600; color: var(--color-text); font-family: var(--font-serif); }
  .page-story-cta { margin-top: 3rem; padding-top: 1.5rem; border-top: 1px solid var(--color-line); text-align: center; font-size: 0.9rem; font-family: var(--font-sans); }
</style>
