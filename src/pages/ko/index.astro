---
/**
 * /ko/index.astro — GSFGrace 홈페이지 KO
 * 일본어 index.astro와 동일한 레이아웃, 한국어 카피 적용
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout
  title="GSFGrace — Hodos Tokyo"
  description="ὁδός. 道. 길. 요한복음 10:10 — 생명을 받고, 함께 걷다."
  lang="ko"
>
  <!-- Hero -->
  <section class="hero">
    <p class="hero-tag">Nihonbashi, Tokyo</p>
    <h1 class="hero-title">
      Receive <span class="green">Life.</span><br />
      Walk Together.
    </h1>
    <p class="hero-tagline">생명을 얻고, 함께 걷다.</p>
    <a href="/ko/story" class="hero-cta" id="hero-story-cta">처음 오셨나요? →</a>
  </section>

  <hr class="rule" />

  <!-- About 2단 -->
  <section class="section-about" aria-labelledby="about-heading">
    <figure class="about-img-wrap">
      <img
        src="/images/hero-nihonbashi.webp"
        alt="니혼바시 다리와 도쿄 거리 풍경"
        width="600"
        height="600"
        loading="lazy"
        decoding="async"
      />
      <figcaption class="about-caption">니혼바시, 도쿄</figcaption>
    </figure>

    <div class="about-text">
      <p class="about-label">About GSFGrace</p>
      <h2 id="about-heading" class="about-body">
        도쿄 니혼바시에서,<br />
        은혜 안에서,<br />
        함께 걷기 위해.
      </h2>
      <p class="about-sub">
        기독교를 향한 질문. 신앙과 일상.<br />
        도쿄에서 복음을 살아가는, 하나하나의 걸음.
      </p>
      <p class="about-sub">
        우리는 '독자'를 늘리기 위해서가 아니라,<br />
        한 사람의 이웃을 만나기 위해 여기 있습니다.
      </p>
      <a href="/ko/story" class="about-link" id="about-story-link">우리에 대하여 →</a>
    </div>
  </section>

  <hr class="rule" />

  <!-- Contents -->
  <section class="section-contents" aria-label="콘텐츠 목록">
    <p class="contents-label">Contents</p>
    <a href="/ko/qa" class="contents-row" id="home-qa-row">
      <span class="contents-title">궁금한 질문</span>
      <span class="contents-desc">하나님이 고통을 허락하시는 이유? 과학과 신앙은 모순인가?</span>
      <span class="contents-arrow">→</span>
    </a>
    <a href="/ko/devotion" class="contents-row" id="home-devotion-row">
      <span class="contents-title">오늘의 묵상</span>
      <span class="contents-desc">매일의 짧은 성경 묵상</span>
      <span class="contents-arrow">→</span>
    </a>
    <a href="/ko/walk" class="contents-row" id="home-walk-row">
      <span class="contents-title">니혼바시 에세이</span>
      <span class="contents-desc">도쿄에서의 선교 일상 기록</span>
      <span class="contents-arrow">→</span>
    </a>
  </section>
</BaseLayout>

<!-- KO 전용 폰트: Hahmlet(세리프) + Noto Sans KR(산세리프) -->
<style is:global>
  @import url('https://fonts.googleapis.com/css2?family=Hahmlet:wght@400;600;700&family=Noto+Sans+KR:wght@400;500;700&display=swap');

  html[lang="ko"] {
    --font-serif: 'Hahmlet', 'Noto Serif KR', Georgia, serif;
    --font-sans:  'Noto Sans KR', system-ui, sans-serif;
  }
</style>

<style>
  /* ── 구분선 ── */
  .rule {
    border: none;
    border-top: 1px solid rgba(0, 0, 0, 0.09);
    margin: 0;
  }

  /* ── Hero ── */
  .hero {
    padding: 3.25rem 0 2.75rem;
  }

  .hero-tag {
    font-size: 0.90rem;
    letter-spacing: 0.20em;
    color: var(--color-muted);
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 1rem;
    font-family: var(--font-sans);
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(4.8rem, 10.5vw, 7.5rem);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.025em;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .hero-title .green {
    color: var(--color-accent);
  }

  .hero-tagline {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 4.8vw, 3.0rem);
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.55;
    margin-bottom: 1.75rem;
    letter-spacing: 0.01em;
  }

  .hero-cta {
    font-size: 1.08rem;
    color: var(--color-text);
    text-decoration: none;
    font-family: var(--font-sans);
    border-bottom: 1px solid var(--color-text);
    padding-bottom: 1px;
    transition: color 0.15s, border-color 0.15s;
  }

  .hero-cta:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
  }

  /* ── About ── */
  .section-about {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    padding: 2.25rem 0 2.5rem;
    align-items: start;
  }

  .about-img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 2px;
    margin: 0;
  }

  .about-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    display: block;
  }

  .about-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.68rem;
    font-family: var(--font-sans);
    padding: 7px 10px;
    letter-spacing: 0.06em;
  }

  .about-text {
    padding-top: 0.2rem;
  }

  .about-label {
    font-size: 0.90rem;
    letter-spacing: 0.18em;
    color: var(--color-muted);
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 0.9rem;
    font-family: var(--font-sans);
  }

  .about-body {
    font-family: var(--font-serif);
    font-size: clamp(1.65rem, 3vw, 2.05rem);
    font-weight: 600;
    line-height: 1.75;
    color: var(--color-text);
    margin-bottom: 1.1rem;
  }

  .about-sub {
    font-size: 1.17rem;
    color: var(--color-muted);
    line-height: 1.85;
    margin-bottom: 0.65rem;
    font-family: var(--font-sans);
  }

  .about-link {
    font-size: 1.17rem;
    color: var(--color-accent);
    font-weight: 500;
    text-decoration: none;
    font-family: var(--font-sans);
    display: inline-block;
    margin-top: 0.65rem;
    transition: color 0.15s;
  }

  .about-link:hover {
    text-decoration: underline;
    color: var(--color-accent-deep);
  }

  /* ── Contents ── */
  .section-contents {
    padding: 1.75rem 0 3.5rem 5.5rem;
  }

  .contents-label {
    font-size: 0.90rem;
    letter-spacing: 0.20em;
    color: var(--color-muted);
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 1rem;
    font-family: var(--font-sans);
  }

  .contents-row {
    display: grid;
    grid-template-columns: 200px 1fr 26px;
    align-items: center;
    padding: 0.9rem 0;
    border-top: 1px solid rgba(0, 0, 0, 0.09);
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.12s;
  }

  .contents-row:last-of-type {
    border-bottom: 1px solid rgba(0, 0, 0, 0.09);
  }

  .contents-row:hover {
    text-decoration: none;
    opacity: 0.75;
  }

  .contents-title {
    font-family: var(--font-serif);
    font-size: 1.32rem;
    font-weight: 600;
    color: var(--color-text);
  }

  .contents-desc {
    font-size: 1.08rem;
    color: var(--color-muted);
    font-family: var(--font-sans);
  }

  .contents-arrow {
    font-size: 1.17rem;
    color: var(--color-muted);
    text-align: right;
  }

  /* ── 반응형 ── */
  @media (max-width: 680px) {
    .section-about {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .section-contents {
      padding-left: 0;
    }

    .contents-row {
      grid-template-columns: 140px 1fr 22px;
    }
  }
</style>
