---
/**
 * index.astro — GSFGrace 홈페이지
 * 디자인 시안 v5 (검토용) 정확 구현
 */
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="GSFGrace — Hodos Tokyo"
  description="ὁδός. 道. 길. ヨハネ10:10 — Receive Life. Walk Together."
  lang="ja"
>
  <!-- Hero -->
  <section class="hero">
    <p class="hero-tag">Nihonbashi, Tokyo</p>
    <h1 class="hero-title">
      Receive <span class="green">Life.</span><br />
      Walk Together.
    </h1>
    <p class="hero-tagline">いのちを受けて、ともに歩む。</p>
    <a href="/story" class="hero-cta" id="hero-story-cta">はじめての方へ →</a>
  </section>

  <hr class="rule" />

  <!-- About 2단 -->
  <section class="section-about" aria-labelledby="about-heading">
    <figure class="about-img-wrap">
      <img
        src="/images/hero-nihonbashi.webp"
        alt="日本橋の橋と東京の街並み"
        width="600"
        height="600"
        loading="lazy"
        decoding="async"
      />
      <figcaption class="about-caption">日本橋, 東京</figcaption>
    </figure>

    <div class="about-text">
      <p class="about-label">About GSFGrace</p>
      <h2 id="about-heading" class="about-body">
        東京・日本橋から、<br />
        恵みのうちに、<br />
        ともに歩むために。
      </h2>
      <p class="about-sub">
        キリスト教への疑問。信仰と日常。<br />
        東京で福音を生きる、一つひとつの歩み。
      </p>
      <p class="about-sub">
        わたしたちは「隣者」を増やすためでなく、<br />
        一人の隣人と出会うために、ここにいます。
      </p>
      <a href="/story" class="about-link" id="about-story-link">わたしたちについて →</a>
    </div>
  </section>

  <hr class="rule" />

  <!-- Contents -->
  <section class="section-contents" aria-label="コンテンツ一覧">
    <p class="contents-label">Contents</p>
    <a href="/qa" class="contents-row" id="home-qa-row">
      <span class="contents-title">疑問に答える</span>
      <span class="contents-desc">なぜ神は苦しみを許すのか？ 科学と信仰は矛盾するか？</span>
      <span class="contents-arrow">→</span>
    </a>
    <a href="/devotion" class="contents-row" id="home-devotion-row">
      <span class="contents-title">今日のみことば</span>
      <span class="contents-desc">毎日の短い聖書の黙想</span>
      <span class="contents-arrow">→</span>
    </a>
    <a href="/walk" class="contents-row" id="home-walk-row">
      <span class="contents-title">日本橋エッセイ</span>
      <span class="contents-desc">東京での宣教の日々の記録</span>
      <span class="contents-arrow">→</span>
    </a>
  </section>
</BaseLayout>

<style>
  /* ── 구분선 ── */
  .rule {
    border: none;
    border-top: 1px solid rgba(0, 0, 0, 0.09);
    margin: 0;
  }

  /* ── Hero ── */
  .hero {
    padding: 3.25rem 0 2.75rem;
  }

  .hero-tag {
    font-size: 0.90rem;
    letter-spacing: 0.20em;
    color: var(--color-muted);
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 1rem;
    font-family: var(--font-sans);
  }

  /* 시안 기준: 680px 뷰에서 ~4.2rem → 1080px에서도 충분히 크게 */
  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(4.8rem, 10.5vw, 7.5rem);
    font-weight: 700;
    line-height: 1.12;
    letter-spacing: -0.025em;
    color: var(--color-text);
    margin-bottom: 1rem;
  }

  .hero-title .green {
    color: var(--color-accent);
  }

  /* 시안 기준: 680px 뷰에서 ~1.85rem */
  .hero-tagline {
    font-family: var(--font-serif);
    font-size: clamp(2.2rem, 4.8vw, 3.0rem);
    font-weight: 400;
    color: var(--color-text);
    line-height: 1.55;
    margin-bottom: 1.75rem;
    letter-spacing: 0.01em;
  }

  .hero-cta {
    font-size: 1.08rem;
    color: var(--color-text);
    text-decoration: none;
    font-family: var(--font-sans);
    border-bottom: 1px solid var(--color-text);
    padding-bottom: 1px;
    transition: color 0.15s, border-color 0.15s;
  }

  .hero-cta:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
  }

  /* ── About ── */
  .section-about {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2.5rem;
    padding: 2.25rem 0 2.5rem;
    align-items: start;
  }

  .about-img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    border-radius: 2px;
    margin: 0;
  }

  .about-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    display: block;
  }

  .about-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.68rem;
    font-family: var(--font-sans);
    padding: 7px 10px;
    letter-spacing: 0.06em;
  }

  .about-text {
    padding-top: 0.2rem;
  }

  .about-label {
    font-size: 0.90rem;
    letter-spacing: 0.18em;
    color: var(--color-muted);
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 0.9rem;
    font-family: var(--font-sans);
  }

  .about-body {
    font-family: var(--font-serif);
    font-size: clamp(1.65rem, 3vw, 2.05rem);
    font-weight: 600;
    line-height: 1.75;
    color: var(--color-text);
    margin-bottom: 1.1rem;
  }

  .about-sub {
    font-size: 1.17rem;
    color: var(--color-muted);
    line-height: 1.85;
    margin-bottom: 0.65rem;
    font-family: var(--font-sans);
  }

  .about-link {
    font-size: 1.17rem;
    color: var(--color-accent);
    font-weight: 500;
    text-decoration: none;
    font-family: var(--font-sans);
    display: inline-block;
    margin-top: 0.65rem;
    transition: color 0.15s;
  }

  .about-link:hover {
    text-decoration: underline;
    color: var(--color-accent-deep);
  }

  /* ── Contents ── */
  .section-contents {
    padding: 1.75rem 0 3.5rem 5.5rem;
  }

  .contents-label {
    font-size: 0.90rem;
    letter-spacing: 0.20em;
    color: var(--color-muted);
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 1rem;
    font-family: var(--font-sans);
  }

  .contents-row {
    display: grid;
    grid-template-columns: 200px 1fr 26px;
    align-items: center;
    padding: 0.9rem 0;
    border-top: 1px solid rgba(0, 0, 0, 0.09);
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.12s;
  }

  .contents-row:last-of-type {
    border-bottom: 1px solid rgba(0, 0, 0, 0.09);
  }

  .contents-row:hover {
    text-decoration: none;
    opacity: 0.75;
  }

  /* 시안 기준 ~0.88rem */
  .contents-title {
    font-family: var(--font-serif);
    font-size: 1.32rem;
    font-weight: 600;
    color: var(--color-text);
  }

  /* 시안 기준 ~0.72rem */
  .contents-desc {
    font-size: 1.08rem;
    color: var(--color-muted);
    font-family: var(--font-sans);
  }

  .contents-arrow {
    font-size: 1.17rem;
    color: var(--color-muted);
    text-align: right;
  }

  /* ── 반응형 ── */
  @media (max-width: 680px) {
    .section-about {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .section-contents {
      padding-left: 0;
    }

    .contents-row {
      grid-template-columns: 110px 1fr 22px;
    }
  }
</style>
