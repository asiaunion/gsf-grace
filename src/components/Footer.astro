---
/**
 * Footer.astro — 시안 v2 기준 심플 푸터
 * 뉴스레터/기도 섹션 제거, 크림 배경 단순 한 줄 푸터
 */
interface Props {
  lang?: 'ja' | 'ko';
}
const { lang = 'ja' } = Astro.props;

const copy = {
  ja: { text: 'GSFGrace — Good Samaritan Flourishing ✦ 日本橋, 東京' },
  ko: { text: 'GSFGrace — Good Samaritan Flourishing ✦ 니혼바시, 도쿄' },
};
const t = copy[lang];
---

<footer class="site-footer">
  <p class="footer-text">{t.text}</p>
</footer>

<style>
  .site-footer {
    border-top: 1px solid rgba(0, 0, 0, 0.09);
    padding: 20px 1.5rem;
    text-align: center;
    background: var(--color-bg);
    margin-top: 0;
  }

  .footer-text {
    font-size: 0.76rem;
    color: var(--color-muted);
    font-family: var(--font-sans);
    letter-spacing: 0.02em;
  }
</style>
