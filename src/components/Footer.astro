---
/**
 * Footer.astro
 * GSFGrace 푸터
 * 스펙: 뉴스레터 CTA + Prayer 섹션 (모든 페이지)
 */
interface Props {
  lang?: 'ja' | 'ko';
}

const { lang = 'ja' } = Astro.props;

const copy = {
  ja: {
    newsletter: {
      heading: '東京からの手紙',
      body: '新しい記事と宣教のことをお届けします。',
      cta: '購読する',
      placeholder: 'メールアドレス',
    },
    prayer: {
      heading: '祈りで共に',
      body: '東京のために祈ってください。\n日本橋に福音の共同体が建てられますように。',
    },
    story: '처음 오셨나요? →',
    copyright: `© ${new Date().getFullYear()} GSFGrace — Hodos Tokyo`,
    location: '日本橋, 東京',
  },
  ko: {
    newsletter: {
      heading: '도쿄에서 보내는 편지',
      body: '새 글과 사역 소식을 전해드립니다.',
      cta: '구독하기',
      placeholder: '이메일 주소',
    },
    prayer: {
      heading: '기도로 함께하기',
      body: '도쿄를 위해 기도해주세요.\n니혼바시에서 복음의 공동체가 세워지도록.',
    },
    story: '처음 오셨나요? →',
    copyright: `© ${new Date().getFullYear()} GSFGrace — Hodos Tokyo`,
    location: '니혼바시, 도쿄',
  },
};

const t = copy[lang];
---

<footer class="site-footer">
  <div class="footer-inner">
    <!-- 뉴스레터 CTA -->
    <section class="footer-newsletter" aria-labelledby="newsletter-heading">
      <h2 id="newsletter-heading" class="footer-section-title">{t.newsletter.heading}</h2>
      <p class="footer-body">{t.newsletter.body}</p>
      <form class="newsletter-form" action="#" method="POST" aria-label="Newsletter signup">
        <input
          type="email"
          name="email"
          id="footer-email"
          placeholder={t.newsletter.placeholder}
          required
          aria-label={t.newsletter.placeholder}
          class="newsletter-input"
        />
        <button type="submit" class="newsletter-btn">{t.newsletter.cta}</button>
      </form>
    </section>

    <!-- Prayer 섹션 -->
    <section class="footer-prayer" aria-labelledby="prayer-heading">
      <h2 id="prayer-heading" class="footer-section-title">{t.prayer.heading}</h2>
      <p class="footer-body prayer-text">{t.prayer.body}</p>
    </section>

    <!-- Story CTA 링크 -->
    <div class="footer-story-cta">
      <a href="/story" class="story-link" id="footer-story-link">{t.story}</a>
    </div>

    <!-- 하단 바 -->
    <div class="footer-bar">
      <p class="footer-copyright">{t.copyright}</p>
      <p class="footer-location">✦ {t.location}</p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: #1c1917;
    color: #d6d3d1;
    padding: 4rem 1.5rem 2rem;
    margin-top: 5rem;
  }

  .footer-inner {
    max-width: 720px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
  }

  .footer-section-title {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #a8a29e;
    margin-bottom: 0.75rem;
  }

  .footer-body {
    font-size: 0.9rem;
    color: #d6d3d1;
    line-height: 1.7;
    white-space: pre-line;
  }

  .newsletter-form {
    display: flex;
    gap: 0.5rem;
    margin-top: 0.75rem;
  }

  .newsletter-input {
    flex: 1;
    padding: 0.5rem 0.75rem;
    background: #292524;
    border: 1px solid #44403c;
    border-radius: 6px;
    color: #f5f5f4;
    font-size: 0.875rem;
    outline: none;
    transition: border-color 0.15s;
  }

  .newsletter-input:focus {
    border-color: #7c3aed;
  }

  .newsletter-input::placeholder {
    color: #78716c;
  }

  .newsletter-btn {
    padding: 0.5rem 1rem;
    background: #7c3aed;
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
    white-space: nowrap;
  }

  .newsletter-btn:hover {
    background: #6d28d9;
  }

  .prayer-text {
    border-left: 2px solid #44403c;
    padding-left: 1rem;
    font-style: italic;
  }

  .footer-story-cta {
    grid-column: 1 / -1;
    text-align: center;
    padding: 1.5rem 0;
    border-top: 1px solid #292524;
    border-bottom: 1px solid #292524;
  }

  .story-link {
    color: #c4b5fd;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: color 0.15s;
  }

  .story-link:hover {
    color: #a78bfa;
    text-decoration: underline;
  }

  .footer-bar {
    grid-column: 1 / -1;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.75rem;
    color: #78716c;
    padding-top: 0.5rem;
  }

  .footer-location {
    letter-spacing: 0.05em;
  }

  @media (max-width: 600px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .newsletter-form {
      flex-direction: column;
    }

    .footer-bar {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
