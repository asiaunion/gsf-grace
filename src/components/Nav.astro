---
/**
 * Nav.astro — STEP 1+2+3
 * STEP 1: 메뉴 5개 (ホーム/信仰と生活 제거, 日本橋エッセイ 반영, arche 괄호 제거)
 * STEP 2: 로고 GSFGrace = olive색, 박스 없음
 * STEP 3: 언어 스위처 — 데스크톱 우측 끝, 모바일 항상 노출
 */
const { lang = 'ja' } = Astro.props as { lang?: 'ja' | 'ko' };

// 현재 경로에서 /ko 접두사 제거한 순수 경로
const rawPath = Astro.url.pathname.replace(/^\/ko/, '') || '/';
const jaUrl = rawPath;
const koUrl = '/ko' + (rawPath === '/' ? '' : rawPath);

const currentPath = Astro.url.pathname;

const navItems = lang === 'ja'
  ? [
      { href: '/story',   label: 'はじめての方へ', highlight: true },
      { href: '/qa',      label: '疑問に答える' },
      { href: '/devotion',label: 'みことば' },
      { href: '/walk',    label: '日本橋エッセイ' },
      { href: '/arche',   label: 'ἀρχή' },
    ]
  : [
      { href: '/ko/story',   label: '처음 오셨나요?', highlight: true },
      { href: '/ko/qa',      label: '궁금한 질문' },
      { href: '/ko/devotion',label: '말씀' },
      { href: '/ko/walk',    label: '니혼바시 에세이' },
      { href: '/ko/arche',   label: 'ἀρχή' },
    ];
---

<nav class="site-nav" aria-label="Main navigation">
  <div class="nav-inner">
    <!-- 로고 pill -->
    <a href={lang === 'ko' ? '/ko' : '/'} class="nav-brand" aria-label="GSFGrace Home">
      <span class="brand-gsf">GSF</span>
      <span class="brand-grace">Grace</span>
    </a>

    <!-- STEP 3: 언어 스위처 — 모바일에서도 항상 노출 (햄버거 밖) -->
    <div class="lang-switch" role="group" aria-label="言語 / 언어">
      <a href={jaUrl} class:list={['lang-opt', { active: lang === 'ja' }]} lang="ja" hreflang="ja">日本語</a>
      <span class="lang-sep" aria-hidden="true">|</span>
      <a href={koUrl} class:list={['lang-opt', { active: lang === 'ko' }]} lang="ko" hreflang="ko">한국어</a>
    </div>

    <button class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="メニューを開く">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <ul class="nav-menu" id="nav-menu" role="list">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'nav-link',
              { active: currentPath === item.href || (currentPath.startsWith(item.href) && item.href !== '/' && item.href !== '/ko') },
              { highlight: item.highlight },
              { 'coming-soon': item.comingSoon },
            ]}
            aria-current={currentPath === item.href ? 'page' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250, 248, 243, 0.92);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--color-line);
  }

  .nav-inner {
    max-width: var(--width-container);   /* 1100 → 1080px 변수화 */
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    height: 64px;
  }

  /* STEP 3: 로고 */
  .nav-brand {
    display: inline-flex;
    flex-direction: row;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    flex-shrink: 0;
    gap: 0.4em;
  }

  .brand-gsf {
    background: var(--color-accent);   /* olive 박스 */
    padding: 0.15rem 0.35rem;
    border-radius: 4px;
    line-height: 1.15;
    font-size: 1.0rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.01em;
    font-family: var(--font-sans);
  }

  .brand-grace {
    font-size: 1.0rem;
    font-weight: 700;
    color: #C5A059; /* premium gold */
    letter-spacing: 0.01em;
    font-family: var(--font-sans);
  }

  /* 언어 스위처 — flex 남은 공간 뒤 왼쪽으로 */
  .lang-switch {
    display: flex;
    align-items: center;
    gap: 0.3rem;
    flex-shrink: 0;
    order: 2;
    margin-left: 2rem;
    padding-right: 0;
  }

  .lang-opt {
    font-size: 0.78rem;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.15s;
    font-family: var(--font-sans);
    white-space: nowrap;
  }

  .lang-opt:hover {
    color: var(--color-accent);
    text-decoration: none;
  }

  .lang-opt.active {
    color: var(--color-accent);
    font-weight: 600;
  }

  .lang-sep {
    font-size: 0.72rem;
    color: var(--color-line);
    user-select: none;
  }

  /* 메뉴 — 로고 바로 옆 */
  .nav-menu {
    display: flex;
    list-style: none;
    gap: 0.3rem;
    flex-wrap: nowrap;
    order: 1;
    flex: 0 1 auto;
    margin-left: 1rem;   /* 로고에 가깝게 */
  }

  .nav-link {
    display: inline-block;
    padding: 0.3rem 0.6rem;
    font-size: 0.82rem;
    color: var(--color-muted);
    border-radius: 4px;
    transition: background 0.15s, color 0.15s;
    text-decoration: none;
    white-space: nowrap;
    font-family: var(--font-sans);
  }

  .nav-link:hover {
    background: var(--color-accent-soft);
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-link.active {
    background: var(--color-accent-soft);
    color: var(--color-accent);
    font-weight: 500;
  }

  /* STEP 2: highlight — 박스 제거, olive 텍스트만 */
  .nav-link.highlight {
    background: transparent;
    color: var(--color-accent);
    font-weight: 600;
  }

  .nav-link.highlight:hover {
    background: var(--color-accent-soft);
    color: var(--color-accent);
  }

  .nav-link.coming-soon {
    color: #a8a29e;
    font-style: italic;
  }

  /* 햄버거 */
  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    flex-shrink: 0;
  }

  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-muted);
    border-radius: 2px;
    transition: transform 0.2s;
  }

  /* ── 모바일 ── */
  @media (max-width: 768px) {
    .nav-inner {
      /* 로고 | 스위처 | 햄버거 순 */
      flex-wrap: nowrap;
    }

    .nav-toggle {
      display: flex;
    }

    /* 스위처: 햄버거 밖에 항상 보임 — order로 햄버거 왼쪽에 고정 */
    .lang-switch {
      order: 1;
      margin-left: auto;
    }

    .nav-toggle {
      order: 2;
      margin-left: 0.5rem;
    }

    .nav-menu {
      order: 10;
      display: none;
      position: absolute;
      top: 60px;
      left: 0;
      right: 0;
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-line);
      padding: 1rem 1.5rem;
      flex-direction: column;
      gap: 0.25rem;
    }

    .nav-menu.open {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(isOpen));
  });
</script>
