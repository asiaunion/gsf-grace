---
/**
 * Nav.astro
 * GSFGrace 네비게이션
 * 스펙: 홈 | 처음 오셨나요? | 오늘의 묵상 | 삶과 신앙 | 걸어가며 | 궁금한 질문 | [準備中] アルケ
 */
interface Props {
  lang?: 'ja' | 'ko';
}

const { lang = 'ja' } = Astro.props;

const navItems = lang === 'ja'
  ? [
      { href: '/', label: 'ホーム' },
      { href: '/story', label: 'はじめての方へ', highlight: true },
      { href: '/devotion', label: '今日のみことば' },
      { href: '/faith-life', label: '信仰と生活' },
      { href: '/walk', label: '歩みながら' },
      { href: '/qa', label: '疑問に答える' },
      { href: '/arche', label: 'ἀρχή（準備中）', comingSoon: true },
    ]
  : [
      { href: '/', label: '홈' },
      { href: '/story', label: '처음 오셨나요?', highlight: true },
      { href: '/devotion', label: '오늘의 묵상' },
      { href: '/faith-life', label: '삶과 신앙' },
      { href: '/walk', label: '걸어가며' },
      { href: '/qa', label: '궁금한 질문' },
      { href: '/arche', label: 'アルケ（준비중）', comingSoon: true },
    ];

const currentPath = Astro.url.pathname;
---

<nav class="site-nav" aria-label="Main navigation">
  <div class="nav-inner">
    <a href="/" class="nav-brand" aria-label="GSFGrace Home">
      <span class="brand-name">GSFGrace</span>
      <span class="brand-sub">Hodos Tokyo</span>
    </a>

    <button class="nav-toggle" id="nav-toggle" aria-expanded="false" aria-controls="nav-menu" aria-label="메뉴 열기">
      <span></span>
      <span></span>
      <span></span>
    </button>

    <ul class="nav-menu" id="nav-menu" role="list">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'nav-link',
              { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) },
              { highlight: item.highlight },
              { 'coming-soon': item.comingSoon },
            ]}
            aria-current={currentPath === item.href ? 'page' : undefined}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250, 250, 249, 0.9);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid #e7e5e4;
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 60px;
  }

  .nav-brand {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    text-decoration: none;
    flex-shrink: 0;
  }

  .brand-name {
    font-size: 1rem;
    font-weight: 700;
    color: #1c1917;
    letter-spacing: -0.02em;
  }

  .brand-sub {
    font-size: 0.65rem;
    color: #78716c;
    letter-spacing: 0.05em;
  }

  .nav-menu {
    display: flex;
    list-style: none;
    gap: 0.25rem;
    flex: 1;
    flex-wrap: wrap;
  }

  .nav-link {
    display: inline-block;
    padding: 0.35rem 0.65rem;
    font-size: 0.85rem;
    color: #57534e;
    border-radius: 6px;
    transition: background 0.15s, color 0.15s;
    text-decoration: none;
    white-space: nowrap;
  }

  .nav-link:hover {
    background: #f5f5f4;
    color: #1c1917;
    text-decoration: none;
  }

  .nav-link.active {
    background: #ede9fe;
    color: #7c3aed;
    font-weight: 500;
  }

  .nav-link.highlight {
    background: #7c3aed;
    color: #fff;
    font-weight: 600;
  }

  .nav-link.highlight:hover {
    background: #6d28d9;
    color: #fff;
  }

  .nav-link.coming-soon {
    color: #a8a29e;
    font-style: italic;
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
    margin-left: auto;
  }

  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    background: #57534e;
    border-radius: 2px;
    transition: transform 0.2s;
  }

  @media (max-width: 768px) {
    .nav-toggle {
      display: flex;
    }

    .nav-menu {
      display: none;
      position: absolute;
      top: 60px;
      left: 0;
      right: 0;
      background: #fafaf9;
      border-bottom: 1px solid #e7e5e4;
      padding: 1rem 1.5rem;
      flex-direction: column;
      gap: 0.25rem;
    }

    .nav-menu.open {
      display: flex;
    }
  }
</style>

<script>
  const toggle = document.getElementById('nav-toggle');
  const menu = document.getElementById('nav-menu');
  toggle?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(isOpen));
  });
</script>
